# novel-to-script 环境变量配置
# 在同根目录下复制此文件为 .env 并填入真实值 便可使用

# --- LLM 提供商选择 ---
N2S_LLM_PROVIDER=deepseek

# --- DeepSeek (推荐 作者测试环境) ---
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat
# 接口完全兼容 OpenAI，无需额外设置 API base

# --- OpenAI ---
# OPENAI_API_KEY=sk-your-key-here
# N2S_OPENAI_MODEL=gpt-4o
# OPENAI_API_BASE=https://api.openai.com/v1

# --- Claude ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# N2S_CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Ollama ---
# OLLAMA_HOST=http://localhost:11434
# N2S_OLLAMA_MODEL=qwen3

# --- 输出 ---
N2S_OUTPUT_DIR=output
